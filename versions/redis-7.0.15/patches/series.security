# series.security —— security-only build profile
#
# 只包含 AOF fallback (RDB corrupted 时降级到 AOF,避免 outage)
# 用于 security-only 维护分支(本仓 6.0.20 即此模式,见其 upstream.yaml meta.lifecycle)
#
# 用法:
#   bash tools/apply_patch.sh <repo> <sha> \
#       versions/redis-7.0.15/patches/series.security \
#       versions/redis-7.0.15/patches \
#       /tmp/build

0004-perf-rdb-fallback-aof.patch
